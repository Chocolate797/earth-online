function drawRadarModal(){
    const dimMap=calcDims(),oldMap=get7DaysAgoDims(),dims=Object.keys(DIMS),values=dims.map(d=>dimMap[d]),oldValues=dims.map(d=>oldMap[d]||0);
    const max=Math.max(...values,...oldValues,1),size=260,canvas=$('#radarModalCanvas');if(!canvas)return;
    canvas.width=size;canvas.height=size;const ctx=canvas.getContext('2d'),cx=size/2,cy=size/2,r=96;ctx.clearRect(0,0,size,size);
    for(let i=1;i<=4;i++){ctx.beginPath();for(let j=0;j<dims.length;j++){const a=Math.PI*2/dims.length*j-Math.PI/2;const x=cx+r*i/4*Math.cos(a),y=cy+r*i/4*Math.sin(a);j===0?ctx.moveTo(x,y):ctx.lineTo(x,y);}ctx.closePath();ctx.strokeStyle=getComputedStyle(document.body).getPropertyValue('--radar-grid').trim()||'#2a2d38';ctx.lineWidth=1;ctx.stroke();}
    for(let i=0;i<dims.length;i++){const a=Math.PI*2/dims.length*i-Math.PI/2;ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx+r*Math.cos(a),cy+r*Math.sin(a));ctx.stroke();ctx.fillStyle=getComputedStyle(document.body).getPropertyValue('--text-secondary').trim()||'#7e8290';ctx.font='bold 9px sans-serif';ctx.textAlign='center';ctx.fillText(DIMS[dims[i]].icon+dims[i],cx+(r+17)*Math.cos(a),cy+(r+17)*Math.sin(a));}
    ctx.setLineDash([6,4]);ctx.beginPath();for(let i=0;i<dims.length;i++){const a=Math.PI*2/dims.length*i-Math.PI/2;const v=oldValues[i]/max*r;i===0?ctx.moveTo(cx+v*Math.cos(a),cy+v*Math.sin(a)):ctx.lineTo(cx+v*Math.cos(a),cy+v*Math.sin(a));}ctx.closePath();ctx.strokeStyle='rgba(150,150,150,0.5)';ctx.lineWidth=2;ctx.stroke();for(let i=0;i<dims.length;i++){const a=Math.PI*2/dims.length*i-Math.PI/2;ctx.beginPath();ctx.arc(cx+oldValues[i]/max*r*Math.cos(a),cy+oldValues[i]/max*r*Math.sin(a),3,0,2*Math.PI);ctx.fillStyle='rgba(150,150,150,0.5)';ctx.fill();}ctx.setLineDash([]);
    ctx.beginPath();for(let i=0;i<dims.length;i++){const a=Math.PI*2/dims.length*i-Math.PI/2;const v=values[i]/max*r;i===0?ctx.moveTo(cx+v*Math.cos(a),cy+v*Math.sin(a)):ctx.lineTo(cx+v*Math.cos(a),cy+v*Math.sin(a));}ctx.closePath();ctx.fillStyle=getComputedStyle(document.body).getPropertyValue('--radar-fill').trim()||'rgba(224,174,60,0.2)';ctx.fill();ctx.strokeStyle=getComputedStyle(document.body).getPropertyValue('--radar-stroke').trim()||'#e0ae3c';ctx.lineWidth=2.5;ctx.stroke();for(let i=0;i<dims.length;i++){const a=Math.PI*2/dims.length*i-Math.PI/2;ctx.beginPath();ctx.arc(cx+values[i]/max*r*Math.cos(a),cy+values[i]/max*r*Math.sin(a),5,0,2*Math.PI);ctx.fillStyle=getComputedStyle(document.body).getPropertyValue('--radar-stroke').trim()||'#e0ae3c';ctx.fill();}
    radarData={values,dims,max};
}
let radarData={};
function bindRadarEvents(){
    const canvas=$('#radarModalCanvas'),tooltip=$('#radarModalTooltip');if(!canvas||!tooltip)return;
    canvas.addEventListener('mousemove',function(e){const rect=this.getBoundingClientRect(),mx=e.clientX-rect.left,my=e.clientY-rect.top,size=260,sX=size/rect.width,sY=size/rect.height,cx=size/2,cy=size/2,r=96;const{values,dims,max}=radarData;let found=false;for(let i=0;i<dims.length;i++){const a=Math.PI*2/dims.length*i-Math.PI/2;const px=cx+values[i]/max*r*Math.cos(a),py=cy+values[i]/max*r*Math.sin(a);if(Math.hypot(mx*sX-px,my*sY-py)<18){tooltip.textContent=`${DIMS[dims[i]].icon} ${dims[i]}：${values[i]} EXP`;tooltip.style.left=(mx+12)+'px';tooltip.style.top=(my-24)+'px';tooltip.classList.add('show');found=true;break;}}if(!found)tooltip.classList.remove('show');});
    canvas.addEventListener('mouseleave',()=>tooltip.classList.remove('show'));
    canvas.addEventListener('click',function(e){const rect=this.getBoundingClientRect(),mx=e.clientX-rect.left,my=e.clientY-rect.top,size=260,sX=size/rect.width,sY=size/rect.height,cx=size/2,cy=size/2,r=96;const{values,dims,max}=radarData;for(let i=0;i<dims.length;i++){const a=Math.PI*2/dims.length*i-Math.PI/2;const px=cx+values[i]/max*r*Math.cos(a),py=cy+values[i]/max*r*Math.sin(a);if(Math.hypot(mx*sX-px,my*sY-py)<22){showToast(`${DIMS[dims[i]].icon} ${dims[i]}：${DIMS[dims[i]].desc}`);return;}}});
}

