$('#helpBtn').addEventListener('click',()=>document.getElementById('helpModal').style.display='flex');
$('#btnPrevTodo').addEventListener('click',()=>{const d=new Date(currentTodoDate);d.setDate(d.getDate()-1);currentTodoDate=getDateStr(d);updateUI();});
$('#btnNextTodo').addEventListener('click',()=>{const d=new Date(currentTodoDate);d.setDate(d.getDate()+1);currentTodoDate=getDateStr(d);updateUI();});
$('#btnTodayTodo').addEventListener('click',()=>{currentTodoDate=getTodayStr();updateUI();});
$('#historyDateFilter').addEventListener('change',()=>{historyFilterDate=$('#historyDateFilter').value;renderRecordList();});
$('#weeklyGoal').addEventListener('change',()=>{weeklyGoal=parseInt($('#weeklyGoal').value);saveAll();updateUI();});
$('#btnGrowthPrev').addEventListener('click',()=>{growthWeekOffset--;if(growthWeekOffset<-12)growthWeekOffset=-12;renderGrowthChart();});
$('#btnGrowthNext').addEventListener('click',()=>{growthWeekOffset++;if(growthWeekOffset>0)growthWeekOffset=0;renderGrowthChart();});
document.querySelectorAll('.theme-dot').forEach(d=>d.addEventListener('click',function(){const t=this.dataset.theme;document.body.classList.remove('theme-light','theme-forest','theme-ocean');if(t==='light')document.body.classList.add('theme-light');else if(t==='forest')document.body.classList.add('theme-forest');else if(t==='ocean')document.body.classList.add('theme-ocean');localStorage.setItem('eoth_v25',t);document.querySelectorAll('.theme-dot').forEach(dd=>dd.classList.toggle('active',dd===this));}));
$('#moodSelector').addEventListener('click',e=>{if(e.target.classList.contains('mood-btn')){todayMood=e.target.dataset.mood;saveAll();renderMood();showToast(`心情：${{'开心':'😊','平静':'😌','充实':'💪','兴奋':'🤩','感恩':'🙏','疲惫':'😫','焦虑':'😰','沮丧':'😞'}[todayMood]} ${todayMood}`);}});
$('#btnPrevMoodMonth').addEventListener('click',()=>{moodViewMonth--;if(moodViewMonth<1){moodViewMonth=12;moodViewYear--;}renderMood();});
$('#btnNextMoodMonth').addEventListener('click',()=>{moodViewMonth++;if(moodViewMonth>12){moodViewMonth=1;moodViewYear++;}renderMood();});

function init(){
    const theme=localStorage.getItem('eoth_v25')||'dark';document.body.classList.remove('theme-light','theme-forest','theme-ocean');if(theme==='light')document.body.classList.add('theme-light');else if(theme==='forest')document.body.classList.add('theme-forest');else if(theme==='ocean')document.body.classList.add('theme-ocean');
    document.querySelectorAll('.theme-dot').forEach(d=>d.classList.toggle('active',d.dataset.theme===theme));
    loadData();
    $('#inputDate').value=getTodayStr();$('#inputMinutes').value='30';$('#weeklyGoal').value=weeklyGoal;
    previousLevel=calcLevel(getTotalExp());const now=new Date();moodViewYear=now.getFullYear();moodViewMonth=now.getMonth()+1;
    bindRadarEvents();
    updateUI();renderMood();
    if(!userProfile){document.getElementById('welcomeModal').style.display='flex';}else{$('#inputProject').focus();}
    setInterval(updateUI,3600000);
}
init();
})();
</script>
</body>
</html>
