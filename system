<script>
(function(){
const $=s=>document.querySelector(s);
const DIMS={'智力':{icon:'🧠',color:'#4fc3f7',desc:'知识储备与认知深度'},'敏捷':{icon:'🗡️',color:'#ffb74d',desc:'工具使用与执行力'},'体质':{icon:'❤️',color:'#81c784',desc:'精力管理与身体健康'},'韧性':{icon:'🛡️',color:'#ba68c8',desc:'心理资本与情绪控制'},'魅力':{icon:'✨',color:'#f06292',desc:'人际连接与影响力'}};
const A2D={'知识学习':'智力','技能实践':'敏捷','体能运动':'体质','心灵成长':'韧性','社交沟通':'魅力'};
const COEFF={'知识学习':1.5,'技能实践':1.3,'体能运动':1.2,'心灵成长':1.0,'社交沟通':1.1};
const BASE=10,TODO_EXP=15,LOTTERY=5000;
const TITLES=[{min:1,title:'觉醒者',icon:'🌱'},{min:2,title:'起步者',icon:'🚶'},{min:3,title:'践行者',icon:'⚡'},{min:4,title:'破壁人',icon:'🔨'},{min:5,title:'专注者',icon:'🎯'},{min:6,title:'心流者',icon:'🌊'},{min:7,title:'塑造者',icon:'🏗️'},{min:8,title:'驾驭者',icon:'🧭'},{min:9,title:'超越者',icon:'🚀'},{min:10,title:'自跃体',icon:'💫'}];
const CITIES=['北京','上海','广州','深圳','成都','杭州','重庆','武汉','西安','南京','长沙','青岛','厦门','大理','丽江','拉萨','三亚','哈尔滨','昆明','桂林','苏州','大连','郑州'];
const BADGES={streak7:{emoji:'🔥',desc:'连续打卡7天'},streak30:{emoji:'💎',desc:'连续打卡30天'},int500:{emoji:'🧠',desc:'智力突破500EXP'},tasks100:{emoji:'✅',desc:'完成100个任务'},total1000:{emoji:'⏱️',desc:'总修行1000分钟'},level5:{emoji:'🌟',desc:'达到Lv.5'}};
const AVATAR={'学生':'🎓','程序员':'💻','设计师':'🎨','教师':'📚','医生':'🏥','销售':'💼','自由职业':'🆓','待业':'⏳','其他':'🎯'};

let records=[],todos=[],pointsHistory=[],totalPoints=0,previousLevel=1,weeklyGoal=0;
let currentTodoDate=getTodayStr(),historyFilterDate='all';
let userProfile=null,todayMood=null,moodRecords={},moodViewYear,moodViewMonth;
let unlockedBadges={},growthWeekOffset=0;

function loadData(){
    try{records=JSON.parse(localStorage.getItem('eor_v25'))||[];}catch(e){records=[];}
    records=records.filter(r=>r&&r.id).map(r=>{if(!r.exp)r.exp=Math.round((r.minutes||0)*BASE*(COEFF[r.ability]||1));return r;}).sort((a,b)=>(b.createdAt||0)-(a.createdAt||0));
    try{todos=JSON.parse(localStorage.getItem('eot_v25'))||[];}catch(e){todos=[];}
    try{totalPoints=parseInt(localStorage.getItem('eop_v25'))||0;pointsHistory=JSON.parse(localStorage.getItem('eoph_v25'))||[];}catch(e){}
    try{userProfile=JSON.parse(localStorage.getItem('eopr_v25'))||null;}catch(e){userProfile=null;}
    try{weeklyGoal=parseInt(localStorage.getItem('eog_v25'))||0;}catch(e){weeklyGoal=0;}
    try{unlockedBadges=JSON.parse(localStorage.getItem('eob_v25'))||{};}catch(e){unlockedBadges={};}
    try{const m=JSON.parse(localStorage.getItem('eom_v25'))||{};moodRecords=m;todayMood=m[getTodayStr()]||null;}catch(e){}
}
function saveAll(){
    localStorage.setItem('eor_v25',JSON.stringify(records));localStorage.setItem('eot_v25',JSON.stringify(todos));
    localStorage.setItem('eop_v25',totalPoints);localStorage.setItem('eoph_v25',JSON.stringify(pointsHistory));
    localStorage.setItem('eopr_v25',JSON.stringify(userProfile));localStorage.setItem('eog_v25',weeklyGoal);
    localStorage.setItem('eob_v25',JSON.stringify(unlockedBadges));
    const m={...moodRecords};m[getTodayStr()]=todayMood;localStorage.setItem('eom_v25',JSON.stringify(m));
}
function getTodayStr(){const d=new Date();return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;}
function getDateStr(d){return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;}
function getTotalExp(){return records.reduce((s,r)=>s+r.exp,0);}
function getTotalMin(){return records.reduce((s,r)=>s+r.minutes,0);}
function calcLevel(exp){return exp<100?1:Math.min(10,Math.floor(Math.sqrt(exp/100)));}
function expForLv(lv){return lv*lv*100;}
function getLvInfo(exp){const lv=calcLevel(exp),cur=lv<=1?0:expForLv(lv-1),next=expForLv(lv),pct=next?Math.min(100,((exp-cur)/next)*100):100;const t=TITLES.find(ti=>ti.min===lv)||TITLES[9];return{level:lv,expIn:exp-cur,expNeed:next,pct,title:t.title,icon:t.icon};}
function calcStreak(){if(!records.length)return 0;const dates=new Set(records.map(r=>r.date));let s=0;for(let i=0;i<365;i++){const d=new Date();d.setDate(d.getDate()-i);if(dates.has(getDateStr(d)))s++;else break;}return s;}
function getWeekMins(offset=0){const now=new Date();const day=now.getDay()||7;const monday=new Date(now);monday.setDate(now.getDate()-day+1+offset*7);monday.setHours(0,0,0,0);const sunday=new Date(monday);sunday.setDate(monday.getDate()+6);sunday.setHours(23,59,59,999);let mins=0;records.forEach(r=>{const d=new Date(r.date+'T12:00:00');if(d>=monday&&d<=sunday)mins+=r.minutes;});return mins;}
function get7DaysAgoDims(){const d=new Date();d.setDate(d.getDate()-7);const map={};Object.keys(DIMS).forEach(k=>map[k]=0);[...records].sort((a,b)=>a.createdAt-b.createdAt).forEach(r=>{if(new Date(r.date+'T12:00:00')<=d)map[A2D[r.ability]||'魅力']+=r.exp;});return map;}
function calcDims(){const map={};Object.keys(DIMS).forEach(k=>map[k]=0);records.forEach(r=>map[A2D[r.ability]||'魅力']+=r.exp);return map;}

function showToast(msg){const t=document.createElement('div');t.className='toast';t.textContent=msg;document.getElementById('toastContainer').appendChild(t);setTimeout(()=>t.remove(),2400);}
function playSound(t){try{const ctx=new AudioContext();const o=ctx.createOscillator();const g=ctx.createGain();o.connect(g);g.connect(ctx.destination);if(t==='levelup'){o.frequency.setValueAtTime(440,0);o.frequency.setValueAtTime(554,0.1);o.frequency.setValueAtTime(659,0.2);g.gain.setValueAtTime(0.2,0);g.gain.exponentialRampToValueAtTime(0.01,0.5);o.start();o.stop(0.5);}else{o.frequency.setValueAtTime(800,0);g.gain.setValueAtTime(0.1,0);g.gain.exponentialRampToValueAtTime(0.01,0.2);o.start();o.stop(0.2);}}catch(e){}}

function checkBadges(){
    const streak=calcStreak(),dims=calcDims(),tasks=records.filter(r=>r.id&&r.id.startsWith('todo_')).length,totalMin=getTotalMin(),lv=calcLevel(getTotalExp());
    if(streak>=7&&!unlockedBadges.streak7){unlockedBadges.streak7=true;saveAll();showToast('🏅 解锁成就：连续打卡7天！');}
